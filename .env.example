# Tokenmesh Configuration
# Copy to .env and fill in your keys

# Server
TOKENMESH_HOST=0.0.0.0
TOKENMESH_PORT=8080
TOKENMESH_LOG_LEVEL=INFO

# Default routing behaviour
# TOKENMESH_DEFAULT_TIER=          # auto (blank) | fast | balanced | frontier
TOKENMESH_DEFAULT_BASELINE_MODEL=openai/gpt-4o

# BYOK — Platform keys (optional, for managed mode)
# Users can also pass keys per-request via headers
# TOKENMESH_OPENAI_API_KEY=sk-...
# TOKENMESH_ANTHROPIC_API_KEY=sk-ant-...
# TOKENMESH_DEEPSEEK_API_KEY=...
# TOKENMESH_QWEN_API_KEY=...
# TOKENMESH_GOOGLE_API_KEY=...
# TOKENMESH_MOONSHOT_API_KEY=...
# TOKENMESH_MISTRAL_API_KEY=...

# Auth
# TOKENMESH_REQUIRE_AUTH=false
# TOKENMESH_ADMIN_API_KEYS=key1,key2

# Managed mode (platform-held keys)
# TOKENMESH_MANAGED_MODE_ENABLED=false
# TOKENMESH_MANAGED_MARKUP_PCT=6.0

# Plan gating
# TOKENMESH_FREE_ROUTING_MODE=basic
# TOKENMESH_PRO_CACHE_ENABLED=true

# Cache
TOKENMESH_CACHE_ENABLED=true
TOKENMESH_CACHE_MAX_SIZE=500
TOKENMESH_CACHE_TTL_SECONDS=3600
TOKENMESH_CACHE_SIMILARITY_THRESHOLD=0.92

# Stripe billing (get from stripe.com/dashboard)
# TOKENMESH_STRIPE_SECRET_KEY=sk_live_...
# TOKENMESH_STRIPE_WEBHOOK_SECRET=whsec_...
# TOKENMESH_STRIPE_PRO_PRICE_ID=price_...
# TOKENMESH_STRIPE_BUSINESS_PRICE_ID=price_...

# Usage DB (default: ~/.tokenmesh/usage.db)
# TOKENMESH_USAGE_DB_PATH=/data/tokenmesh/usage.db
